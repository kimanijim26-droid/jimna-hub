      if (!origin.endsWith('.run.app') && !origin.includes('localhost') && origin !== window.location.origin) {
        return;
      }
      
      if (event.data?.type === 'DERIV_AUTH_CODE') {
        const { code, state } = event.data;
        if (code && state) {
          executeTokenExchange(code, state);
        }
      }
    };
    
