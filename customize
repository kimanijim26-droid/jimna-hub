      addLog("System reset complete. All cached credentials purged.", "warning");
    }
  };

  const handleManualAuth = async () => {
    if (!tempToken) {
      setAuthError('Please enter an API Token');
      return;
    }
    
    setIsValidating(true);
    setAuthError(null);
    setAuthErrorCode(null);
